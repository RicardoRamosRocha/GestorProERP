<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - Veltis ERP</title>

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
</head>
<body>

    <div class="d-flex">

        <div class="bg-dark text-white p-3"
             style="width:250px;min-height:100vh;">

            <h4>Veltis ERP</h4>

            <hr />

            <ul class="nav flex-column">

                <li class="nav-item">
                    <a class="nav-link text-white" asp-area="Admin" asp-controller="Home" asp-action="Index">
                        Dashboard
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link text-white" asp-area="Admin" asp-controller="Clientes" asp-action="Index">
                        Clientes
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link text-white" asp-area="Admin" asp-controller="Fornecedores" asp-action="Index">
                        Fornecedores
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link text-white" asp-area="Admin" asp-controller="Produtos" asp-action="Index">
                        Produtos
                    </a>
                </li>

            </ul>

        </div>

        <div class="container-fluid p-4">
            @RenderBody()
        </div>

    </div>

</body>
</html>